# =============================================================================
# Jarvis – environment variables
# Copy this file to `.env` and fill in the values you need.
# Anything marked (optional) can be left blank; the agent will skip the related
# tool / feature at runtime.
# =============================================================================

# ----- Model (required) ------------------------------------------------------
# Anthropic API key used by the default Jarvis agent (Claude Opus 4.6).
ANTHROPIC_API_KEY=

# Override the default model. Format: "<provider>:<model-id>".
# Defaults to "anthropic:claude-opus-4-6". Examples:
#   anthropic:claude-opus-4-6
#   anthropic:claude-sonnet-4-6
#   openai:gpt-5.4
JARVIS_MODEL=anthropic:claude-opus-4-6

# Sampling temperature for the default model. 0 = deterministic.
JARVIS_TEMPERATURE=0

# ----- Tools (optional) ------------------------------------------------------
# Tavily web search. Without this key the `internet_search` tool is disabled.
TAVILY_API_KEY=

# ----- Composio (optional) ---------------------------------------------------
# https://composio.dev unified tool platform. Used by Jarvis to access
# pre-built integrations (Shopify, Gmail, GitHub, …). Without this key the
# Composio toolkits declared on each agent are skipped with a warning.
COMPOSIO_API_KEY=

# Composio user id. Every Composio call is scoped to a user; use "default" for
# a single-tenant setup, or a real user id when running multi-user.
COMPOSIO_USER_ID=default

# ----- Sandbox (optional, recommended for skill scripts + shell tools) -------
# Deno Deploy access token. When set, every agent gets a Deno sandbox as its
# default backend, which adds the `execute` tool (shell) and lets skills with
# executable scripts actually run them. Get a token at
# https://app.deno.com → Settings → Organization Tokens (org tokens start
# with `ddo_`; personal tokens start with `ddp_` and require DENO_DEPLOY_ORG).
DENO_DEPLOY_TOKEN=

# Required only for personal (`ddp_`) tokens.
# DENO_DEPLOY_ORG=

# Sandbox idle TTL. "session" keeps it alive for the lifetime of this process;
# duration strings ("20m", "1h", "30s") auto-expire after idle. Default
# "session". Use a duration if you're worried about leaking sandboxes.
JARVIS_SANDBOX_TIMEOUT=session

# Sandbox memory budget (768MiB – 4GiB).
JARVIS_SANDBOX_MEMORY=1GiB

# ----- Observability (optional, recommended) ---------------------------------
# Uncomment to enable LangSmith tracing of every run.
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=scandi-jarvis

# ----- WhatsApp frontend (optional; required to run `npm run wa:server`) -----
# Base URL of the scandi-wa-bot HTTP API (no trailing slash).
WA_BOT_BASE_URL=http://127.0.0.1:8787
# Bearer token configured as API_AUTH_TOKEN on the WA bot.
WA_BOT_TOKEN=
# Shared secret returned by `POST /v1/webhooks` when registering this app
# as a subscriber. Used to verify HMAC-SHA256 signatures on webhook deliveries.
WA_WEBHOOK_SECRET=

# Whitelist of chat JIDs Jarvis is allowed to respond in.
# - Empty / unset (default) = no chats allowed (fail closed).
# - "*" = allow all chats (use only for local dev or trusted single-tenant).
# - comma-separated list, e.g.
#     JARVIS_WA_ALLOWED_CHATS=120363012345678901@g.us,359884430293@s.whatsapp.net
JARVIS_WA_ALLOWED_CHATS=

# Fastify bind. Defaults to 127.0.0.1:3000 — terminate TLS at a reverse proxy.
JARVIS_WA_HOST=127.0.0.1
JARVIS_WA_PORT=3000

# Quiet-window before triggering a run after the last inbound message arrives
# (resets on every new message in the same chat). Default 5s.
JARVIS_WA_DEBOUNCE_MS=5000

# Max time to wait for `message.processed` on media before proceeding without
# the AI summary. Default 60s.
JARVIS_WA_MEDIA_WAIT_MS=60000

# How many recent messages to include in the context block per turn.
JARVIS_WA_CONTEXT_MSGS=30

# Model used for chat summarisation (daily / weekly / long-term).
JARVIS_SUMMARY_MODEL=anthropic:claude-sonnet-4-6

# Per-run hard caps on outbound WA tool calls (prevents runaway agents).
JARVIS_WA_MAX_SENDS_PER_RUN=8
JARVIS_WA_MIN_SEND_INTERVAL_MS=500

# Postgres connection string. Used by:
#   - jarvis.chat_context (summaries + AGENTS.md-style notes)
#   - jarvis.wa_webhook_seen (webhook idempotency)
#   - @langchain/langgraph-checkpoint-postgres (per-chat thread checkpoints)
# Hosted Supabase Postgres works (use the "Connection pooler" string for
# transactions if your runtime opens many connections).
SUPABASE_DB_URL=

# ----- Workflows (optional) --------------------------------------------------
# Deterministic scheduled tasks that run independently of the chat agent and
# report results back via the WhatsApp REST API.
# See docs/WORKFLOWS.md for how to add a new one.

# Default destination chat for workflow notifications. Workflows can override
# this individually (e.g. WORKFLOW_REVOLUT_CHAT_JID below).
JARVIS_WORKFLOWS_DEFAULT_CHAT_JID=

# Revolut expenses API — required for the `revolut-daily-expenses` workflow.
# Base URL of the scandi-revolut-expenses HTTP API (no trailing slash).
REVOLUT_EXPENSES_API_BASE_URL=
REVOLUT_EXPENSES_API_KEY=
# Optional per-workflow chat override; falls back to the default above.
WORKFLOW_REVOLUT_CHAT_JID=

# ----- Runtime (optional) ----------------------------------------------------
# debug | info | warn | error  (default: info)
LOG_LEVEL=info
